# Copy to `.env` at repo root (never commit `.env`).
# Flutter client (envied @ lib/core/env/env.dart)
WEB_API_KEY=
WEB_APP_ID=
WEB_AUTH_DOMAIN=
ANDROID_API_KEY=
ANDROID_APP_ID=
IOS_API_KEY=
IOS_APP_ID=
IOS_BUNDLE_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Staging / prod app — Serverpod (when wired; see docs/infra/staging-and-production.md)
# SERVERPOD_HOST=api-staging.example.com
# SERVERPOD_PORT=8080
# SERVERPOD_SCHEME=https

# Server runtime only (never ship to Flutter)
# DATABASE_URL=postgresql://user:pass@host:5432/chat_staging
# REDIS_URL=redis://localhost:6379
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-adminsdk.json
